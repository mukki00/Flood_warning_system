# Copy this file to flask_api/.env and fill values.
# Do NOT commit real secrets.

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
FLASK_SECRET_KEY=change-me

# ── MQTT Broker (local broker recommended for full offline mode) ──────────
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_DATA=flood/node1/data
MQTT_TOPIC_ALERTS=flood/alerts/local
MQTT_CLIENT_ID=FlaskFloodAPI

# ── In-memory storage ───────────────────────────────────────────────────────
MAX_RECORDS=500

# ── Azure Cosmos DB (optional; leave blank for offline-only mode) ─────────
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=FloodWarningDB
COSMOS_CONTAINER=SensorReadings

# ── Azure Event Hub (optional; leave blank for offline-only mode) ─────────
EVENTHUB_CONN_STR=
EVENTHUB_NAME=flood-events

# ── Redis local-first cache / offline queue ────────────────────────────────
# Use either REDIS_URL or host/port settings below.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

REDIS_KEY_READINGS=flood:readings
REDIS_KEY_ALERTS=flood:alerts
REDIS_KEY_SYNC_QUEUE=flood:sync:readings
ALERTS_MAX_RECORDS=200

# ── Cloud sync controls ─────────────────────────────────────────────────────
# Keep true for hybrid mode (store local + sync to cloud when reachable).
# Set false for strict offline-only mode.
SYNC_TO_COSMOS=true
SYNC_TO_EVENTHUB=true
ENABLE_BACKGROUND_SYNC=true
SYNC_BATCH_SIZE=50
SYNC_INTERVAL_SECONDS=5
